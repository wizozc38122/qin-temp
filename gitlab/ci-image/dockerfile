# ============================================================
# God CI Image — Fastest Exporting Layers Edition
# ============================================================

FROM mcr.microsoft.com/dotnet/sdk:8.0-jammy

ENV TZ=Asia/Taipei \
    DOTNET_CLI_TELEMETRY_OPTOUT=1 \
    DOTNET_NOLOGO=1

# ------------------------------------------------------------
# ☕ Java 17 JDK & Maven 3.9.9 — 用 ADD 直接解壓
# ------------------------------------------------------------
RUN mkdir -p /opt/java/openjdk /opt/maven
ADD binaries/openjdk-17-jdk.tar.gz /opt/java/openjdk/
ADD binaries/apache-maven-3.9.9-bin.tar.gz /opt/maven/

# 將內部自帶版本號的目錄結構拉平，讓路徑固定
RUN mv /opt/java/openjdk/jdk-*/* /opt/java/openjdk/ && rm -rf /opt/java/openjdk/jdk-* \
    && mv /opt/maven/apache-maven-*/* /opt/maven/ && rm -rf /opt/maven/apache-maven-*

ENV JAVA_HOME=/opt/java/openjdk
ENV MAVEN_HOME=/opt/maven
ENV PATH="${JAVA_HOME}/bin:${MAVEN_HOME}/bin:${PATH}"

# ------------------------------------------------------------
# 🟣 .NET SDKs  直接 ADD 解壓（各 1 layer）
# ------------------------------------------------------------
ADD binaries/dotnet-sdk-5.0.tar.gz /usr/share/dotnet/
ADD binaries/dotnet-sdk-3.1.tar.gz /usr/share/dotnet/

# ------------------------------------------------------------
# 🔧 SonarScanner（唯一一次寫大量小檔）
# ------------------------------------------------------------
COPY binaries/dotnet-sonarscanner.nupkg /tmp/

RUN dotnet tool install --global dotnet-sonarscanner \
        --add-source /tmp \
        --ignore-failed-sources \
    && rm -f /tmp/dotnet-sonarscanner.nupkg \
    && dotnet nuget locals all --clear

ENV PATH="${PATH}:/root/.dotnet/tools"

# ------------------------------------------------------------
# 🟢 Node.js (透過 ADD 離線解壓，包含 20.17.0 與 22.14.0)
# ------------------------------------------------------------
RUN mkdir -p /opt/node/v20 /opt/node/v22
ADD binaries/node-v20.17.0-linux-x64.tar.xz /opt/node/v20/
ADD binaries/node-v22.14.0-linux-x64.tar.xz /opt/node/v22/

# 拉平目錄結構
RUN mv /opt/node/v20/node-*/* /opt/node/v20/ && rm -rf /opt/node/v20/node-* \
    && mv /opt/node/v22/node-*/* /opt/node/v22/ && rm -rf /opt/node/v22/node-*

# 預設使用 Node 20.17.0，若需使用 22.14.0 可以在 ci 腳本中修改 PATH
ENV NODE20_HOME=/opt/node/v20
ENV NODE22_HOME=/opt/node/v22
ENV PATH="${NODE20_HOME}/bin:${PATH}"

# 全域啟用 corepack 以支援 pnpm 與 yarn (離線可用)
RUN corepack enable

# ------------------------------------------------------------
# 🔵 通用 Sonar Scanner CLI (供 Node.js 等使用)
# ------------------------------------------------------------
RUN mkdir -p /opt/sonar-scanner
ADD binaries/sonar-scanner-cli.tar.gz /opt/sonar-scanner/
RUN mv /opt/sonar-scanner/sonar-scanner-*/* /opt/sonar-scanner/ && rm -rf /opt/sonar-scanner/sonar-scanner-*/ \
    && chmod +x /opt/sonar-scanner/bin/sonar-scanner
ENV PATH="/opt/sonar-scanner/bin:${PATH}"

# ------------------------------------------------------------
# 🏁 Workdir & quick sanity check
# ------------------------------------------------------------
WORKDIR /workspace

RUN java -version \
    && mvn -version \
    && dotnet --list-sdks \
    && dotnet-sonarscanner --version \
    && node -v \
    && npm -v \
    && sonar-scanner -v || true